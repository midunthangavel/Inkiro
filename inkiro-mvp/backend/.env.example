# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection used by scripts/migrate.js. Supabase dashboard →
# Settings → Database → Connection string → "URI" (use the pooled 6543 port).
DATABASE_URL=postgresql://postgres:<db-password>@db.wxqtivchgptjcfqpjbpk.supabase.co:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-48-chars

# ─── Admin ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_API_KEY=replace-with-a-strong-random-key

# ─── SMS ──────────────────────────────────────────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-key-here

# ─── Google AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# CORS: use "*" in development; in production set comma-separated allowed origins
# Example (prod): CORS_ORIGINS=https://admin.inkiro.in,https://shop.inkiro.in
CORS_ORIGINS=*

# ─── Observability (optional) ─────────────────────────────────────────────────
# Forwards 5xx errors, uncaught exceptions, Socket.IO errors, and cron failures
# to Sentry. Leave empty to disable external reporting (logs still go to stdout).
# When enabling, also run: npm install @sentry/node
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
